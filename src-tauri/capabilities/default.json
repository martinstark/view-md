{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default window capabilities for mdv",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:webview:allow-set-webview-zoom",
    "opener:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://*" },
        { "url": "http://*" }
      ]
    }
  ]
}
